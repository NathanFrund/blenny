<div class="hero min-h-screen bg-base-200">
  <div class="hero-content flex-col lg:flex-row-reverse">
    <div class="text-center lg:text-left">
      <h1 class="text-5xl font-bold">Join Blenny!</h1>
      <p class="py-6">Create an account to get started. It's fast and easy.</p>
    </div>
    <div class="card shrink-0 w-full max-w-sm shadow-2xl bg-base-100">
      <form
        class="card-body"
        method="POST"
        action="/register"
        hx-post="/register"
        hx-target="#register-form"
        hx-swap="outerHTML"
      >
        <div id="register-form">{{> auth/register_form}}</div>
      </form>
    </div>
  </div>
</div>
